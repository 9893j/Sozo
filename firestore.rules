rules_version = '2';

// ─────────────────────────────────────────────
//  SOZO COMUNIDADE CRISTÃ — Regras de Produção
// ─────────────────────────────────────────────
//  Hierarquia de roles (do menor para o maior):
//  visitante < membro < lider < pastor < super_admin
// ─────────────────────────────────────────────

service cloud.firestore {
  match /databases/{database}/documents {

    // ═══ Helpers ═══════════════════════════════

    function isSignedIn() {
      return request.auth != null;
    }

    // Pega o documento do usuário autenticado
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // Pega o role do usuário autenticado (ou 'visitante' se não logado)
    function myRole() {
      return isSignedIn() ? getUserData().role : 'visitante';
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // ── Hierarquia sem indexOf() ──────────────
    // O Firestore Rules não tem .indexOf() em listas,
    // então comparamos role por role usando OR direto.
    function isMembroOrAbove() {
      let r = myRole();
      return r == 'membro' || r == 'lider' || r == 'pastor' || r == 'super_admin';
    }

    function isLiderOrAbove() {
      let r = myRole();
      return r == 'lider' || r == 'pastor' || r == 'super_admin';
    }

    function isPastorOrAbove() {
      let r = myRole();
      return r == 'pastor' || r == 'super_admin';
    }

    function isSuperAdmin() {
      return myRole() == 'super_admin';
    }

    // ═══ users ═════════════════════════════════
    match /users/{userId} {
      allow read: if isSignedIn();

      // Criação do próprio documento no primeiro login
      allow create: if isOwner(userId)
        && request.resource.data.role == 'membro';

      // O próprio usuário pode editar campos pessoais,
      // MAS não pode alterar seu próprio "role" ou "active"
      allow update: if isOwner(userId)
        && request.resource.data.role == resource.data.role
        && request.resource.data.active == resource.data.active;

      // Pastor/super_admin podem alterar qualquer campo de qualquer usuário,
      // exceto a própria conta (proteção extra)
      allow update: if isPastorOrAbove() && userId != request.auth.uid;

      // Só super_admin pode deletar contas (e não a própria)
      allow delete: if isSuperAdmin() && userId != request.auth.uid;
    }

    // ═══ members ════════════════════════════════
    match /members/{memberId} {
      allow read: if isSignedIn();
      allow create, update: if isLiderOrAbove();
      allow delete: if isPastorOrAbove();
    }

    // ═══ ministerios ════════════════════════════
    match /ministerios/{minId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isLiderOrAbove();
    }

    // ═══ escalas ════════════════════════════════
    match /escalas/{escalaId} {
      allow read: if isSignedIn();
      allow create, update: if isLiderOrAbove();
      allow delete: if isPastorOrAbove();
    }

    // ═══ eventos ════════════════════════════════
    match /eventos/{eventoId} {
      allow read: if true; // landing page pública lê eventos
      allow create, update: if isLiderOrAbove();
      allow delete: if isPastorOrAbove();
    }

    // ═══ prayers ════════════════════════════════
    match /prayers/{prayerId} {
      allow read: if isSignedIn();
      allow create: if isMembroOrAbove()
        && request.resource.data.authorUid == request.auth.uid;
      allow update: if isMembroOrAbove();
      allow delete: if isLiderOrAbove();
    }

    // ═══ posts ══════════════════════════════════
    match /posts/{postId} {
      allow read: if true; // landing page lê posts publicados
      allow create, update: if isLiderOrAbove();
      allow delete: if isPastorOrAbove();
    }

    // ═══ live ═══════════════════════════════════
    match /live/{liveId} {
      allow read: if true;
      allow write: if isPastorOrAbove();
    }

    // ═══ Bloqueio padrão ════════════════════════
    match /{document=**} {
      allow read, write: if false;
    }
  }
}